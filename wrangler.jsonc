{
  // UtilityX — Cloudflare Workers/Pages wrangler config
  "name": "utilityx",
  "compatibility_date": "2026-04-18",
  "assets": {
    "directory": "./"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
